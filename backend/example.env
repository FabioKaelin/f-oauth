FRONTEND_ORIGIN=http://localhost:3000

JWT_SECRET=my_ultra_secure_secret
TOKEN_EXPIRED_IN=60m
TOKEN_MAXAGE=60

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/api/sessions/oauth/google

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost:8000/api/sessions/oauth/github

INTERNAL_TIPP_URL=prod-backend.tipp.svc.cluster.local
INTERNAL_DEV_TIPP_URL=dev-backend.tipp.svc.cluster.local

# Email (Gmail SMTP) — required for password reset emails
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=F-OAuth
EMAIL_SMTP_PASSWORD=

# Password Reset
RESET_PASSWORD_TOKEN_EXPIRY=10800
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
